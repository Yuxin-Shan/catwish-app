# Mobile app safe defaults
# 默认只允许 mock provider；真实第三方 AI 应优先通过 backend 代理
EXPO_PUBLIC_AI_PROVIDER=mock
EXPO_PUBLIC_ENABLE_DIRECT_AI=false

# Local-only keys for Node scripts or backend development
# 不要把这些值放进客户端 bundle
KIMI_API_KEY=sk-your_kimi_api_key_here
MOONSHOT_API_KEY=sk-your_moonshot_api_key_here

# Claude API配置（可选）
ANTHROPIC_API_KEY=sk-your_claude_api_key_here

# OpenAI API配置（可选）
OPENAI_API_KEY=sk-your_openai_api_key_here
