# AI服务配置
# 选择AI提供者: kimi, claude, gpt4v, mock
AI_PROVIDER=kimi

# KIMI API配置（推荐）
# 获取方式: https://platform.moonshot.cn/
KIMI_API_KEY=sk-your_kimi_api_key_here
MOONSHOT_API_KEY=sk-your_moonshot_api_key_here

# Claude API配置（可选）
ANTHROPIC_API_KEY=sk-your_claude_api_key_here

# OpenAI API配置（可选）
OPENAI_API_KEY=sk-your_openai_api_key_here
